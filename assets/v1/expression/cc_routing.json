{
  "_comment": "Per-mood per-layer default CC routing. Static = set once at section start; phrase-arc = ramped over phrase; lfo = continuous LFO at given Hz. All values are abstract intents; render layer lowers them to actual CCs based on synth capability flags from dim #12.",
  "moods": {
    "ambient":     {"pad":   {"cc11":"phrase-arc[60,90]", "cc74_lfo":{"hz":0.1,"depth":15}, "cc91":110, "cc93":80, "cc1_vibrato":false}},
    "lofi":        {"keys":  {"cc11":"mild-sway[70,90]", "cc64":"on-chord-change", "cc91":70, "cc74_offset":-10}},
    "upbeat-pop":  {"lead":  {"cc11":"flat[100]", "cc1_vibrato":"long-notes", "cc91":50, "cc93":30}},
    "cinematic":   {"strings":{"cc11":"phrase-arc[40,120]", "cc1":"paired-with-cc11", "cc2_if_breath_aware":true, "cc91":120}},
    "edm":         {"lead":  {"cc74":"per-bar-automation", "pitch_bend":"phrase1-scoops", "cc91":40}},
    "jazz-trio":   {"piano": {"cc64":"on-chord-change", "cc11":"phrase-arc[50,100]", "cc1_vibrato":false}},
    "dub":         {"bass":  {"cc11":"halftime-wobble", "pitch_bend":"phrase-end-slide"}},
    "techno":      {"lead":  {"cc74":"sweep-8bar", "cc1":"pulse-16th"}},
    "trap":        {"bass":  {"pitch_bend":"808-slide", "cc74":"sub-emphasis"}},
    "rock":        {"guitar":{"cc11":"flat[100]", "pitch_bend":"hammer-on-slides", "cc1_vibrato":"sustained-bends"}}
  },
  "static_cc_init": {
    "_at_tick_0_per_channel": ["cc7_volume", "cc10_pan", "cc91_reverb_send", "cc93_chorus_send", "rpn_pitch_bend_range"],
    "_section_change_ramp_ticks": 64
  },
  "merge_rule": {
    "_comment": "CC11 and CC74 may be written by both phrase-arc and per-note articulation. Sources are SUMMED into a virtual signal in SongSpec, then flushed to MIDI as one stream at render time. Never write the same CC from two raw sources."
  },
  "limits": {
    "default_cc_events_per_sec": 30,
    "tremolo_cc_events_per_sec": 32,
    "smf_legibility_target": 30
  }
}

        "kick"
      ],
      "mutates_rows": [
        "snare",
        "ghost_snare"
      ],
      "param_schema": {
        "start_velocity": "int",
        "end_velocity": "int",
        "subdiv": "int",
        "span_steps": "int"
      },
      "bpm_clamp_max_subdiv": {
        "<=110": 32,
        "111-140": 16,
        ">140": 16
      }
    },
    {

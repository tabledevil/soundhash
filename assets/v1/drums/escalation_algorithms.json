{
  "version": "soundhash/v1/drums/escalation_algorithms",
  "comment": "Eight escalation + eight de-escalation algorithms. param_schema entries are type strings; concrete params are sampled per-bar via HKDF label 'perbar/drums/<i>'. bpm_clamp_max_subdiv enforces a humane top-end subdivision so 32nd-note hat ramps are not selected at 170 BPM.",
  "escalation": [
    {
      "id": "linear_add",
      "name": "Linear Add",
      "preserves_rows": [
        "kick",
        "snare"
      ],
      "mutates_rows": [
        "hat_closed",
        "perc_1",
        "perc_2"
      ],
      "param_schema": {
        "add_per_bar": "int",
        "max_steps": "int"
      },
      "bpm_clamp_max_subdiv": {
        "<=110": 32,
        "111-140": 16,
        ">140": 8
      }
    },
    {
      "id": "subdivision_double",
      "name": "Subdivision Double",
      "preserves_rows": [
        "kick",
        "snare"
      ],
      "mutates_rows": [
        "hat_closed",
        "hat_open"
      ],
      "param_schema": {
        "start_subdiv": "int",
        "end_subdiv": "int",
        "ramp_bars": "int"
      },
      "bpm_clamp_max_subdiv": {
        "<=110": 32,
        "111-140": 16,
        ">140": 8
      }
    },
    {
      "id": "tom_rollup",
      "name": "Tom Rollup",
      "preserves_rows": [
        "kick"
      ],
      "mutates_rows": [
        "tom_high",
        "tom_mid",
        "tom_low",
        "snare"
      ],
      "param_schema": {
        "start_bar": "int",
        "span_steps": "int",
        "velocity_curve": "str"
      },
      "bpm_clamp_max_subdiv": {
        "<=110": 16,
        "111-140": 16,
        ">140": 8
      }
    },
    {
      "id": "snare_roll_crescendo",
      "name": "Snare Roll Crescendo",

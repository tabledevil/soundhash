{
  "version": "soundhash/v1/melody/phrase_shapes",
  "_doc": "Phrase-shape templates. structure is an ordered list of (motif_role, transform). motif_role is the symbolic slot ('A','B','A_aug',etc.). transform is one of mutation_operators ids or 'identity'. length_bars is the canonical bar count; packing_function specifies how to scale to actual bar count of the form's melodic section. tags drive form/mood compatibility filtering.",
  "shapes": [
    {"id": "ps_AABA", "name": "AABA", "structure": [["A","identity"],["A","identity"],["B","identity"],["A","identity"]], "length_bars": 4, "packing_function": "stretch_each_role_to_bar_groups; if total_bars==8 each slot=2 bars; if 16 each=4", "tags": ["pop","ballad","jazz_head","symmetric"]},
    {"id": "ps_period_4_4", "name": "period_4_4", "structure": [["A","identity"],["A","truncate"],["A","transpose+1"],["A","cadence"]], "length_bars": 4, "packing_function": "fixed_4_or_double_to_8", "tags": ["classical","pop","symmetric","cadence"]},
    {"id": "ps_sentence_2_2_4", "name": "sentence_2_2_4", "structure": [["A","identity"],["A","sequence+1"],["B","identity"],["B","cadence"]], "length_bars": 4, "packing_function": "fixed_4_or_double_to_8 (B becomes 2-bar continuation when 8)", "tags": ["classical","sentence","build"]},
    {"id": "ps_q_a", "name": "q_a", "structure": [["Q","identity"],["A","identity"]], "length_bars": 2, "packing_function": "fixed_2_or_double_to_4 (each role becomes 2 bars)", "tags": ["call_response","blues","folk"]},
    {"id": "ps_climb_release", "name": "climb_release", "structure": [["A","identity"],["A","sequence+1"],["A","sequence+2"],["B","cadence"]], "length_bars": 4, "packing_function": "fixed_4; if 8 bars each slot doubles", "tags": ["build","climax","cinematic"]},
    {"id": "ps_hook_first", "name": "hook_first", "structure": [["H","identity"],["A","identity"],["H","identity"],["B","cadence"]], "length_bars": 4, "packing_function": "fixed_4_or_8", "tags": ["pop","hook","earworm"]},
    {"id": "ps_call_response_2_2", "name": "call_response_2_2", "structure": [["C","identity"],["R","identity"],["C","ornament"],["R","cadence"]], "length_bars": 4, "packing_function": "each_role_1_bar_or_2", "tags": ["call_response","gospel","funk","blues"]},
    {"id": "ps_pickup_then_8", "name": "pickup_then_8", "structure": [["P","identity"],["A","identity"],["A","identity"],["B","identity"],["A","cadence"]], "length_bars": 9, "packing_function": "pickup is half-bar; A/B slots flex 1-2 bars; total = pickup + 8±1", "tags": ["pickup","jazz","standard"]},
    {"id": "ps_7_plus_tag", "name": "7_plus_tag", "structure": [["A","identity"],["A","identity"],["B","identity"],["A","identity"],["T","cadence"]], "length_bars": 8, "packing_function": "7 bars main + 1 bar tag (T is 1-bar cadential extension)", "tags": ["asymmetric","tag","jazz"]},
    {"id": "ps_cad_extension", "name": "cad_extension", "structure": [["A","identity"],["A","identity"],["B","identity"],["B","cadence"],["E","identity"]], "length_bars": 5, "packing_function": "4-bar phrase + 1-bar cadential echo; flex to 8+2", "tags": ["cadence","extension","ballad"]},
    {"id": "ps_1_bar_tail", "name": "1_bar_tail", "structure": [["A","identity"],["A","identity"],["B","cadence"],["T","truncate"]], "length_bars": 4, "packing_function": "T is short tail; usable as 4 or 8 bar form's last sub-phrase", "tags": ["short","tail","fragmentation"]},
    {"id": "ps_half_cadence_antecedent", "name": "half_cadence_antecedent", "structure": [["A","identity"],["A","sequence+1"],["B","identity"],["B","half_cadence"]], "length_bars": 4, "packing_function": "antecedent only; pair with a consequent shape downstream when form length permits", "tags": ["antecedent","half_cadence","classical"]},
    {"id": "ps_ostinato_loop", "name": "ostinato_loop", "structure": [["A","identity"],["A","identity"],["A","identity"],["A","ornament"]], "length_bars": 4, "packing_function": "tile to any bar count; ornament every 4th repetition", "tags": ["ostinato","minimal","ambient","techno"]},
    {"id": "ps_ABAC", "name": "ABAC", "structure": [["A","identity"],["B","identity"],["A","identity"],["C","cadence"]], "length_bars": 4, "packing_function": "fixed_4_or_8", "tags": ["pop","jazz","through_composed"]},
    {"id": "ps_ABCD_through", "name": "ABCD_through", "structure": [["A","identity"],["B","sequence+1"],["C","invert"],["D","cadence"]], "length_bars": 4, "packing_function": "fixed_4_or_8; through-composed", "tags": ["through_composed","cinematic","glitch"]},
    {"id": "ps_rondo_ABACA", "name": "rondo_ABACA", "structure": [["A","identity"],["B","identity"],["A","identity"],["C","identity"],["A","cadence"]], "length_bars": 5, "packing_function": "5-slot; works at 5,10 bars (A=1 or 2)", "tags": ["rondo","classical","return"]}
  ]
}

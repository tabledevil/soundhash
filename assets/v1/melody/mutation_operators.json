    {"id": "op_truncate",     "name": "truncate",     "applicable_time_sigs": ["4/4","6/8","3/4","12/8","7/8","5/4"], "preserves_phrase_coherence": true,  "weight_by_phrase_position": [0.0, 0.5, 1.0, 1.5]},
    {"id": "op_augment",      "name": "augment",      "applicable_time_sigs": ["4/4","6/8","3/4","12/8"],              "preserves_phrase_coherence": true,  "weight_by_phrase_position": [0.0, 0.0, 0.5, 1.5]},
    {"id": "op_diminute",     "name": "diminute",     "applicable_time_sigs": ["4/4","6/8","3/4","12/8","7/8","5/4"], "preserves_phrase_coherence": true,  "weight_by_phrase_position": [0.5, 1.5, 1.5, 0.0]},
    {"id": "op_ornament",     "name": "ornament",     "applicable_time_sigs": ["4/4","6/8","3/4","12/8","7/8","5/4"], "preserves_phrase_coherence": true,  "weight_by_phrase_position": [0.5, 1.0, 1.0, 1.0]},
    {"id": "op_sequence_p1",  "name": "sequence+1",   "applicable_time_sigs": ["4/4","6/8","3/4","12/8"],              "preserves_phrase_coherence": true,  "weight_by_phrase_position": [0.0, 1.5, 1.5, 0.5]},
    {"id": "op_sequence_m1",  "name": "sequence-1",   "applicable_time_sigs": ["4/4","6/8","3/4","12/8"],              "preserves_phrase_coherence": true,  "weight_by_phrase_position": [0.0, 1.5, 1.5, 0.5]}

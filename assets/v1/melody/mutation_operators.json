  "filter_rules": [
    "5/4 or 7/8 → exclude op_augment (overflow).",
    "energy_bar < 0.3 → exclude op_diminute.",
    "phrase_position == final_cadence → only {op_identity, op_truncate, op_augment}.",
    "mood == M0 (Ambient) → exclude {op_ornament, op_diminute}.",
    "motif.symmetry_safe == false → exclude {op_invert, op_retro_rhythm}.",
    "cumulative_transpose would exceed tessitura → sign-flipped at table-build time."

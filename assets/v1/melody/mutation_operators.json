  "operators": [
    {"id": "op_identity",     "name": "identity",     "applicable_time_sigs": ["4/4","6/8","3/4","12/8","7/8","5/4"], "preserves_phrase_coherence": true,  "weight_by_phrase_position": [2.0, 1.0, 1.0, 1.5]},
